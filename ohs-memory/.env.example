# OHS Memory — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Anthropic API (for PDF text extraction only) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── OpenAI API (for embeddings — used by BOTH ingest.py and search-proxy.php) ─
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ── Supabase (PostgreSQL + pgvector) ─────────────────────────────────────────
# Settings → Database → Connection string → URI  (for ingest.py direct writes)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Settings → API → Project URL
SUPABASE_URL=https://[project-ref].supabase.co

# Settings → API → Project API Keys → anon / public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
